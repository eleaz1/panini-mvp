# Copy this to .env and fill in your values
APP_NAME=LAMINY
DEBUG=false

# For production use PostgreSQL (Supabase Session Pooler):
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite+aiosqlite:///./panini.db

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

CORS_ORIGINS=["http://localhost:4200","http://localhost:80"]

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:4200

# SMTP — leave SMTP_USER empty to log emails to console in dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@laminy.app

# Google reCAPTCHA v2
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMHkFl5cPVqNPLz5
RECAPTCHA_ENABLED=false

# Admin user (created on first run via seeder)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@laminy.app
ADMIN_PASSWORD=change-me-in-production
