# Copy this to .env and fill in your values
APP_NAME=Panini MVP
DEBUG=false

# For production use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/panini
DATABASE_URL=sqlite+aiosqlite:///./panini.db

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

CORS_ORIGINS=["http://localhost:4200","http://localhost:80"]

# Resend SMTP — https://resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxx
SMTP_FROM=onboarding@resend.dev
