# Copy to backend/.env on the server and fill in ALL values marked with <...>

APP_NAME=LAMINY
DEBUG=false

# PostgreSQL via Docker Compose service named "db"
DATABASE_URL=postgresql+asyncpg://laminy:<DB_PASSWORD>@db:5432/laminy

# Generate with: openssl rand -hex 32
SECRET_KEY=<generate-with-openssl-rand-hex-32>

CORS_ORIGINS=["http://<SERVER_IP>","https://<YOUR_DOMAIN>"]
FRONTEND_URL=http://<SERVER_IP>

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<gmail-address>
SMTP_PASSWORD=<gmail-app-password>
SMTP_FROM=noreply@laminy.app

# reCAPTCHA (set to true when domain is configured)
RECAPTCHA_SECRET_KEY=<your-recaptcha-secret>
RECAPTCHA_ENABLED=false

# PostgreSQL credentials (must match docker-compose POSTGRES_PASSWORD)
POSTGRES_PASSWORD=<DB_PASSWORD>
POSTGRES_USER=laminy
POSTGRES_DB=laminy

# Admin user (created on first run)
ADMIN_USERNAME=admin
ADMIN_EMAIL=<admin-email>
ADMIN_PASSWORD=<strong-password>
